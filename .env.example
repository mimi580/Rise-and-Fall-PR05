# ============================================================
# DERIV RISE/FALL BOT — Railway Environment Variables
# Copy these into Railway → Variables tab
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────
DERIV_API_TOKEN=your_deriv_api_token_here
DERIV_APP_ID=1089

# ── CONTRACT ─────────────────────────────────────────────────
SYMBOL=1HZ100V

# ── RISK / MARTINGALE ─────────────────────────────────────────
INITIAL_STAKE=1.00
MARTINGALE_MUL=1.5
MAX_LOSSES=5
TARGET_PROFIT=10.0
STOP_LOSS=20.0

# ── SIGNAL MODEL THRESHOLDS ──────────────────────────────────
# Sliding window size for bias + markov
WINDOW_SIZE=100
MIN_WINDOW=50

# Bernoulli bias gate
BIAS_RISE=0.52
BIAS_FALL=0.48

# Markov chain threshold
MARKOV_THRESH=0.55

# Momentum (last N ticks, |M| to fire)
MOM_WINDOW=5
MOM_THRESH=3

# Multi-step conditional probability
COND_THRESH=0.60
COND_SAMPLES=30

# Combined score gate
COMBINED_THRESH=0.60

# Weighted score model weights (must sum to 1.0)
W_BIAS=0.30
W_MARKOV=0.40
W_MOM=0.30

# ── VOLATILITY FILTER ─────────────────────────────────────────
VOL_MIN=0.0001
VOL_MAX=0.0020

# ── EV EXPIRY OPTIMISER ───────────────────────────────────────
# Minimum EV required to trade a given expiry (0 = any positive)
MIN_EV=0.0
# Minimum historical trades before EV gate activates
MIN_EV_HIST=10

# ── CIRCUIT BREAKER ───────────────────────────────────────────
CONSEC_LOSS_LIMIT=3
CONSEC_PAUSE_SECS=600

# ── TRADE PACING ─────────────────────────────────────────────
# Evaluate signal every N ticks (reduces noise)
EVAL_EVERY=3

# ── RESILIENCE ───────────────────────────────────────────────
LOCK_TIMEOUT=30
BUY_RETRIES=8
RECONNECT_MIN=2
RECONNECT_MAX=60
WS_PING=30
ORPHAN_ATTEMPTS=4
ORPHAN_INTERVAL=3
